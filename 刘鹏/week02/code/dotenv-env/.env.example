# ============================================================
# 配置模板（.env.example）
# 用途：提交到 Git，告诉团队成员需要配置哪些变量
# 使用：复制为对应文件后填入真实值
#   cp .env.example .env
#   cp .env.example .env.models
# ============================================================

# ==================== .env 通用配置 ====================
# 环境标识：dev / prod
APP_ENV=dev

# 思考模式
ENABLE_THINKING=true
REASONING_EFFORT=high

# 请求参数
MAX_TOKENS=4096
TIMEOUT=120
MAX_RETRIES=3

# 应用
DEBUG=false
LOG_LEVEL=INFO


# ==================== .env.models 模型配置 ====================
# 命名规则：{别名大写}_API_KEY / _BASE_URL / _MODEL / _PROVIDER
#
# PROVIDER 决定 API 格式：
#   openai    → OpenAI Chat Completions 格式（DeepSeek / Qwen）
#   anthropic → Anthropic Messages 格式（Claude）

# DeepSeek（OpenAI 格式）
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_PROVIDER=openai

# 通义千问（OpenAI 格式）
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_PROVIDER=openai

# Claude（Anthropic 格式）
CLAUDE_API_KEY=sk-ant-your-claude-key
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_PROVIDER=anthropic

# 当前激活模型（切换只改这一行）
ACTIVE_MODEL=deepseek
