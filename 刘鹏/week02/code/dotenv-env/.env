# ============================================================
# 通用默认配置（.env）
# 所有环境共享的基础配置，环境差异写在 .env.dev / .env.prod 中
# ============================================================

# ===== 环境标识 =====
# 可选值：dev / prod
# 推荐通过系统环境变量覆盖，而非修改此文件
APP_ENV=dev

# ===== 思考模式 =====
ENABLE_THINKING=true
REASONING_EFFORT=high

# ===== 请求参数（默认值，可被 .env.dev/.env.prod 覆盖） =====
MAX_TOKENS=4096
TIMEOUT=120
MAX_RETRIES=3

# ===== 应用 =====
DEBUG=false
LOG_LEVEL=INFO
